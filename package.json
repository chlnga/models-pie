{
  "name": "models-pie",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Models Pie — find the best LLM for your fast / cheap / good priorities. Client-side only.",
  "repository": {
    "type": "git",
    "url": "https://github.com/chlnga/models-pie.git"
  },
  "homepage": "https://modelspie.com",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "fetch:data": "node scripts/fetch-data.mjs",
    "build:data": "node scripts/build-data.mjs",
    "setup": "npm run fetch:data && npm run build:data"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
